{
  "$schema": "https://raw.githubusercontent.com/nicktomlin/tauri/tauri-v2.0.0/crates/tauri-utils/schema.json",
  "productName": "Visualize Physics",
  "version": "0.3.0",
  "identifier": "io.visualizephysics.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Visualize Physics — Quantum & Statistical Physics",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
